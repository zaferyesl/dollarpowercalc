# CPI (optional)
FRED_API_KEY=

# GA4 override (optional)
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# NextAuth — required for admin
AUTH_SECRET=

# Single admin credential (plaintext email + bcrypt hash of password — never commit real secrets)
ADMIN_EMAIL=
ADMIN_PASSWORD_HASH=

# Password hash helper (local only):
#   npm run hash-admin-password -- "YourStrongSecretHere"

# Supabase — URLs & keys from Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SERVER ONLY — never expose to browser
SUPABASE_SERVICE_ROLE_KEY=
